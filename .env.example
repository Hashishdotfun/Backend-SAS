HOST=0.0.0.0
PORT=8080
RUST_LOG=info,hashish_backend=debug

# Set to true to run without Solana (attestation verification only)
ATTESTATION_ONLY=true

# Required only when ATTESTATION_ONLY=false
# SOLANA_RPC_URL=https://api.devnet.solana.com
# AUTHORITY_KEYPAIR_PATH=./authority-keypair.json
# PROGRAM_ID=Ai9XrxSUmDLNCXkoeoqnYuzPgN9F2PeF9WtLq9GyqER

# Optional
# JWT_SECRET=change-me-to-random-secret
# JWT_EXPIRY_HOURS=168
# DATABASE_PATH=./data/devices.db
